{
  "name": "@gridmason/protocol",
  "version": "0.2.0",
  "description": "Gridmason contracts + verification library: the types, wire formats, and pure verify core every host, CLI, and registry meet on.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gridmason/protocol.git"
  },
  "bugs": {
    "url": "https://github.com/gridmason/protocol/issues"
  },
  "homepage": "https://github.com/gridmason/protocol#readme",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./canon": {
      "types": "./dist/canon/index.d.ts",
      "import": "./dist/canon/index.js"
    },
    "./verify": {
      "types": "./dist/verify/index.d.ts",
      "import": "./dist/verify/index.js"
    },
    "./negotiate": {
      "types": "./dist/negotiate/index.d.ts",
      "import": "./dist/negotiate/index.js"
    },
    "./vectors": {
      "types": "./dist/vectors/index.d.ts",
      "import": "./dist/vectors/index.js"
    },
    "./schemas/manifest.json": "./schemas/manifest.schema.json",
    "./schemas/signature-envelope.json": "./schemas/signature-envelope.schema.json",
    "./schemas/revocation-feed.json": "./schemas/revocation-feed.schema.json",
    "./schemas/log-entry.json": "./schemas/log-entry.schema.json",
    "./schemas/trust-root.json": "./schemas/trust-root.schema.json",
    "./schemas/gmb-bundle.json": "./schemas/gmb-bundle.schema.json",
    "./schemas/gate-snapshot.json": "./schemas/gate-snapshot.schema.json",
    "./schemas/import-map-fragment.json": "./schemas/import-map-fragment.schema.json"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run schemas && tsc -p tsconfig.build.json",
    "schemas": "node scripts/gen-schemas.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "10.0.1",
    "@types/node": "22.10.5",
    "@vitest/coverage-v8": "4.1.10",
    "ajv": "8.17.1",
    "eslint": "10.7.0",
    "ts-json-schema-generator": "2.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
